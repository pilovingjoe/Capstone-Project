; Engine configuration file.
; It's best edited using the editor UI and not directly,
; since the parameters that go here are not all obvious.
;
; Format:
;   [section] ; section goes between []
;   param=value ; assign values to parameters

config_version=5

[animation]

compatibility/default_parent_skeleton_in_mesh_instance_3d=true

[application]

config/name="BluetoothAppTest"
run/main_scene="uid://bsejyk6kmnvii"
config/features=PackedStringArray("4.6", "Forward Plus")
run/low_processor_mode=true
run/delta_smoothing=false
boot_splash/image="uid://d614cbqy768m"
config/icon="res://icon.svg"

[autoload]

BlePermissionsManager="*uid://01w12s2xkxqa"
BLEManager="*uid://dh3mtbx8ddlg4"

[display]

window/size/viewport_height=1920
window/energy_saving/keep_screen_on=false
window/handheld/orientation=1
window/vsync/vsync_mode=0

[editor_plugins]

enabled=PackedStringArray("res://addons/godotandroidble/plugin.cfg")

[gui]

theme/custom="uid://bse16ypjw5veu"

[input_devices]

pointing/emulate_touch_from_mouse=true

[physics]

2d/run_on_separate_thread=true
3d/physics_engine="Jolt Physics"

[rendering]

rendering_device/driver.windows="d3d12"
renderer/rendering_method="gl_compatibility"
renderer/rendering_method.mobile="gl_compatibility"
textures/vram_compression/import_etc2_astc=true
